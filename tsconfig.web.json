{
  "include": ["src/renderer/src/**/*"],
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "outDir": "out/renderer",
    "paths": {
      "@renderer/*": ["src/renderer/src/*"]
    }
  }
}
